TEXT 2192 1680 Left 2 !.tran 0 5m 0\n \n.meas TRAN Vout_peak MAX V(OUT)\n.meas TRAN t_peak FIND TIME WHEN V(OUT)=Vout_peak RISE=1\n.meas TRAN Vout_SS AVG V(OUT) FROM 4m TO 5m\n.meas TRAN overshoot PARAM (Vout_peak - Vout_SS) / Vout_SS * 100\n.meas TRAN t_settle FIND TIME WHEN V(OUT)=12.24 FALL=1\n.meas TRAN t_settle2 FIND TIME WHEN V(OUT)=12.00 CROSS=2
