TEXT 2360 1592 Left 2 !.param VIN=9.6\n.tran 0 10m 5m uic\n \n; --- PRE-STEP BASELINE ---\n.meas TRAN Vout_before AVG V(OUT) FROM 0 TO 0.4m\n.meas TRAN Vin_before AVG V(IN) FROM 0 TO 0.4m\n.meas TRAN Vout_ripple_pre PP V(OUT) FROM 0 TO 0.4m\n \n; --- EVENT 1: 0.1A to 1.5A ---\n.meas TRAN Vout_droop1 MIN V(OUT) FROM 0.5m TO 1.4m\n.meas TRAN Vout_post1 AVG V(OUT) FROM 1.0m TO 1.4m\n.meas TRAN Vin_droop1 MIN V(IN) FROM 0.5m TO 1.4m\n \n; --- INTER-EVENT ---\n.meas TRAN Vout_idle AVG V(OUT) FROM 2.1m TO 3.4m\n \n; --- EVENT 2: 0.1A to 2.0A ---\n.meas TRAN Vout_droop2 MIN V(OUT) FROM 3.5m TO 4.4m\n.meas TRAN Vout_post2 AVG V(OUT) FROM 3.8m TO 4.4m\n.meas TRAN Vin_droop2 MIN V(IN) FROM 3.5m TO 4.4m\n \n; --- POST-STEP METRICS ---\n.meas TRAN Vout_ripple PP V(OUT) FROM 3.8m TO 4.4m\n.meas TRAN IL_peak MAX I(L1) FROM 3.9m TO 4.4m\n.meas TRAN IL_peak_pre MAX I(L1) FROM 0 TO 0.4m\n.meas TRAN Pin AVG V(IN)*(-I(V1)) FROM 4.2m TO 4.4m\n.meas TRAN Pout AVG V(OUT)*I(I1) FROM 3.8m TO 4.4m\n \n; --- DERIVED METRICS ---\n.meas TRAN LoadReg PARAM abs(Vout_before-Vout_post2)\n.meas TRAN Eff PARAM Pout/Pin*100\n.meas TRAN Vin_drop1 PARAM Vin_before-Vin_droop1\n.meas TRAN Vin_drop2 PARAM Vin_before-Vin_droop2
TEXT 2360 2536 Left 2 !.meas DC_dev RMS V(out) - 12.1985
