TEXT 2192 1680 Left 2 !.param VIN=8.0\n.tran 0 10m 5m\n \n.meas TRAN Vout_before AVG V(OUT) FROM 0 TO 0.4m\n.meas TRAN Vout_droop1 MIN V(OUT) FROM 0.5m TO 1.4m\n.meas TRAN Vout_recov1 FIND TIME WHEN V(OUT)=12.15 CROSS=2 TD=0.5m\n.meas TRAN Vout_idle AVG V(OUT) FROM 2.1m TO 3.4m\n.meas TRAN Vout_droop2 MIN V(OUT) FROM 3.5m TO 4.4m\n.meas TRAN Vout_recov2 FIND TIME WHEN V(OUT)=12.15 CROSS=2 TD=3.5m\n.meas TRAN Vout_ripple PP V(OUT) FROM 3.6m TO 4.4m\n.meas TRAN IL_peak MAX I(L1) FROM 0 TO 0.4m\n.meas TRAN Pin AVG V(IN)*(-I(V1)) FROM 3.6m TO 4.4m\n.meas TRAN Pout AVG V(OUT)*I(I1) FROM 3.6m TO 4.4m
